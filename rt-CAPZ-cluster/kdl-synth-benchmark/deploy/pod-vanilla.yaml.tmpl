# Vanilla mode: the SAME workload image and SAME taskset as RT mode, but with
# NO ResourceClaim — plain CFS scheduling via cpu requests/limits = m cores.
# This is the control that should miss deadlines under contention.
# Placeholders substituted by experiments/run_all.sh:
#   {{IMAGE}} {{TASKSET}} {{Q}} {{P}} {{M}} {{RUN_ID}} {{NODE}}
#   {{JOBS}} {{WARMUP}} {{UTIL}} {{N_TASKS}} {{INTERFERENCE}} {{TASKSET_ID}}
apiVersion: v1
kind: Pod
metadata:
  name: vanilla-workload-{{RUN_ID}}
  namespace: kdl-bench
  labels:
    app: kdl-workload
    mode: vanilla
spec:
  restartPolicy: Never
  nodeSelector:
    kubernetes.io/hostname: {{NODE}}
  tolerations:
    - key: rt
      operator: Exists
      effect: NoSchedule
  volumes:
    - name: out
      emptyDir: {}
    - name: taskset
      configMap:
        name: taskset-{{RUN_ID}}
  containers:
    - name: workload
      image: {{IMAGE}}
      imagePullPolicy: IfNotPresent
      args:
        - "--taskset"
        - "/tasksets/{{TASKSET}}"
        - "--out"
        - "/out/metrics.jsonl"
        - "--jobs"
        - "{{JOBS}}"
        - "--warmup"
        - "{{WARMUP}}"
        - "--run-id"
        - "{{RUN_ID}}"
        - "--taskset-id"
        - "{{TASKSET_ID}}"
        - "--mode"
        - "vanilla"
        - "--budget-q-us"
        - "{{Q}}"
        - "--period-p-us"
        - "{{P}}"
        - "--cores-m"
        - "{{M}}"
        - "--util"
        - "{{UTIL}}"
        - "--interference"
        - "{{INTERFERENCE}}"
        - "--node"
        - "{{NODE}}"
        - "--kernel"
        - "cfs"
      # Same nominal CPU share as the reservation (m cores), but NO temporal
      # or budget isolation — the whole point of the comparison.
      resources:
        requests:
          cpu: "{{M}}"
        limits:
          cpu: "{{M}}"
      volumeMounts:
        - name: out
          mountPath: /out
        - name: taskset
          mountPath: /tasksets
          readOnly: true
